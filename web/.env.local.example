# Copy to .env.local for local dev, and set the same vars in Vercel project settings.

# Public (read-only, safe to expose to the browser) — Supabase anon key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only (NEVER prefix with NEXT_PUBLIC) — used inside /api/shoe for live lookups.
KICKSDB_API_KEY=YOUR-KICKSDB-KEY

# Optional: pricing market for live KicksDB detail fetches (default US). Match config.yaml.
KICKSDB_MARKET=US
