<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sneaker Flip Opportunities</title>
</head>
{# ---- helper macros ---- #}
{% macro money(v) -%}{% if v is not none %}{{ cur }}{{ "{:,.0f}".format(v) }}{% else %}—{% endif %}{%- endmacro %}
{% macro stat(label, value, alt) -%}
  <tr style="background:{{ '#f8fafc' if alt else '#ffffff' }};">
    <td style="padding:7px 10px;color:#64748b;font-size:12px;border-bottom:1px solid #f1f5f9;">{{ label }}</td>
    <td style="padding:7px 10px;color:#0f172a;font-size:13px;font-weight:600;text-align:right;border-bottom:1px solid #f1f5f9;">{{ value }}</td>
  </tr>
{%- endmacro %}
{% macro btn(href, label, primary) -%}
  <a href="{{ href }}" style="display:inline-block;text-decoration:none;font-size:13px;font-weight:600;padding:9px 14px;border-radius:8px;
     {% if primary %}background:#111827;color:#ffffff;{% else %}background:#ffffff;color:#111827;border:1px solid #cbd5e1;{% endif %}">{{ label }}</a>
{%- endmacro %}
<body style="margin:0;padding:0;background:#eef2f6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#0f172a;-webkit-font-smoothing:antialiased;">
  <div style="max-width:680px;margin:0 auto;padding:20px 14px;">

    <!-- Header -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#111827;border-radius:14px;">
      <tr><td style="padding:22px 24px;">
        <div style="font-size:24px;font-weight:800;color:#ffffff;letter-spacing:-0.4px;">👟 Weekly Sneaker Flip Report</div>
        <div style="font-size:13px;color:#94a3b8;margin-top:6px;">
          {{ generated_at }} &nbsp;·&nbsp; {{ brands|join(' + ') }} &nbsp;·&nbsp; {{ market }} market
          &nbsp;·&nbsp; sorted by {{ 'soonest release' if sort_by == 'date' else 'profit' }}
        </div>
        <div style="margin-top:14px;display:inline-block;background:#16a34a;color:#ffffff;font-size:14px;font-weight:700;padding:6px 14px;border-radius:999px;">
          {{ opportunities|length }} opportunit{{ 'y' if opportunities|length == 1 else 'ies' }}
        </div>
      </td></tr>
    </table>

    {% if not opportunities %}
      <div style="background:#ffffff;border-radius:14px;padding:32px;text-align:center;color:#64748b;margin-top:16px;border:1px solid #e2e8f0;">
        No releases cleared the profit thresholds this week. Try lowering
        <code>min_profit</code> / <code>min_margin</code> in config.yaml.
      </div>
    {% endif %}

    {% for o in opportunities %}
    {% set r = o.release %}
    {% set s = r.stats %}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#ffffff;border:1px solid #e2e8f0;border-radius:14px;margin-top:16px;">
      <tr><td style="padding:18px 20px;">

        <!-- Title row -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td width="30" valign="top">
              <div style="width:24px;height:24px;line-height:24px;text-align:center;background:#111827;color:#fff;border-radius:7px;font-size:12px;font-weight:700;">{{ loop.index }}</div>
            </td>
            <td width="64" valign="top" style="padding-left:6px;">
              {% if r.image_url %}<img src="{{ r.image_url }}" width="60" height="60" alt="" style="border-radius:10px;background:#f1f5f9;object-fit:contain;">{% endif %}
            </td>
            <td valign="top" style="padding-left:12px;">
              <div style="font-size:16px;font-weight:700;line-height:1.3;letter-spacing:-0.2px;">{{ r.name }}</div>
              <div style="color:#64748b;font-size:12px;margin-top:3px;">
                {{ r.brand }} &nbsp;·&nbsp; {{ r.sku }}{% if r.release_date %} &nbsp;·&nbsp; <span style="color:#0f172a;font-weight:600;">drops {{ r.release_date.strftime('%a %d %b %Y') }}</span>{% endif %}
              </div>
            </td>
            <td valign="top" align="right" width="96">
              <div style="background:#dcfce7;border-radius:10px;padding:8px 10px;display:inline-block;text-align:center;">
                <div style="font-size:19px;font-weight:800;color:#15803d;line-height:1;">+{{ money(o.profit) }}</div>
                <div style="font-size:11px;color:#16a34a;font-weight:600;margin-top:3px;">{{ "%.0f"|format(o.margin * 100) }}% margin</div>
              </div>
            </td>
          </tr>
        </table>

        <!-- Buy vs resell headline -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:16px;">
          <tr>
            <td width="33%" style="padding:10px 12px;background:#f8fafc;border-radius:10px;">
              <div style="font-size:10px;letter-spacing:0.6px;color:#94a3b8;font-weight:700;text-transform:uppercase;">Buy at retail</div>
              <div style="font-size:18px;font-weight:800;margin-top:3px;">{{ money(r.retail_price) }}</div>
            </td>
            <td width="8"></td>
            <td width="33%" style="padding:10px 12px;background:#f8fafc;border-radius:10px;">
              <div style="font-size:10px;letter-spacing:0.6px;color:#94a3b8;font-weight:700;text-transform:uppercase;">Resell ({{ resale_signal }})</div>
              <div style="font-size:18px;font-weight:800;margin-top:3px;">{{ money(o.resale_price) }}</div>
            </td>
            <td width="8"></td>
            <td width="33%" style="padding:10px 12px;background:#f0fdf4;border-radius:10px;">
              <div style="font-size:10px;letter-spacing:0.6px;color:#16a34a;font-weight:700;text-transform:uppercase;">Net payout</div>
              <div style="font-size:18px;font-weight:800;margin-top:3px;color:#15803d;">{{ money(o.net_payout) }}</div>
            </td>
          </tr>
        </table>

        <!-- Detailed market data -->
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:14px;border:1px solid #f1f5f9;border-radius:10px;overflow:hidden;">
          {{ stat("Lowest / avg / highest ask", money(r.lowest_ask) ~ " / " ~ money(r.avg_price) ~ " / " ~ money(r.highest_ask), false) }}
          {{ stat("Sales — last 90 days", (s.last_90_days_sales_count if s and s.last_90_days_sales_count else "—") ~ ("  (avg " ~ money(s.last_90_days_average_price) ~ ")" if s and s.last_90_days_average_price else ""), true) }}
          {{ stat("Sales — last 12 months", (s.annual_sales_count if s and s.annual_sales_count else "—") ~ ("  (avg " ~ money(s.annual_average_price) ~ ")" if s and s.annual_average_price else ""), false) }}
          {{ stat("12-month price range", (money(s.annual_low) ~ " – " ~ money(s.annual_high)) if s and s.annual_high else "—", true) }}
          {{ stat("Volatility / resale premium", (("%.0f%%"|format(s.annual_volatility * 100)) if s and s.annual_volatility is not none else "—") ~ "  /  " ~ (("%.2fx"|format(s.annual_price_premium)) if s and s.annual_price_premium is not none else "—"), false) }}
          {{ stat("Weekly orders / annual $ volume", (r.weekly_orders if r.weekly_orders else "—") ~ "  /  " ~ money(s.annual_total_dollars if s else none), true) }}
        </table>

        <!-- Actions -->
        <table role="presentation" cellpadding="0" cellspacing="0" style="margin-top:16px;">
          <tr>
            <td style="padding-right:8px;">{{ btn("https://www.soleretriever.com/search?query=" ~ (r.name|urlencode), "🎟 Enter raffles", true) }}</td>
            <td style="padding-right:8px;">{{ btn("https://www.nike.com/w?q=" ~ (r.name|urlencode), "Search Nike", false) }}</td>
            {% if r.stockx_url %}<td>{{ btn(r.stockx_url, "View on StockX", false) }}</td>{% endif %}
          </tr>
        </table>

      </td></tr>
    </table>
    {% endfor %}

    <!-- Raffle sites footer -->
    {% if raffle_sites %}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#ffffff;border:1px solid #e2e8f0;border-radius:14px;margin-top:20px;">
      <tr><td style="padding:18px 20px;">
        <div style="font-size:13px;font-weight:700;color:#0f172a;margin-bottom:10px;">🎟 Where to take your chances</div>
        {% for site in raffle_sites %}
          <a href="{{ site.url }}" style="display:inline-block;text-decoration:none;font-size:13px;color:#111827;font-weight:600;background:#f1f5f9;border-radius:8px;padding:8px 12px;margin:0 8px 8px 0;">{{ site.name }} ↗</a>
        {% endfor %}
      </td></tr>
    </table>
    {% endif %}

    <p style="color:#94a3b8;font-size:11px;margin:18px 4px 8px;line-height:1.6;">
      Profit = resale signal ({{ resale_signal }}) minus {{ "%.0f"|format(fee_pct * 100) }}% fees{% if shipping_cost %} and {{ money(shipping_cost) }} shipping{% endif %}, minus retail.
      Asks are seller listings (StockX exposes no bids via this API); statistics may be blank for brand-new releases.
      Estimates only — verify on StockX before buying. Resale markets are volatile.
    </p>
  </div>
</body>
</html>
