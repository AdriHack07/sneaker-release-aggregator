# Copy to .env for local runs (never commit .env). In GitHub Actions these are Secrets.

# KicksDB API key — get one at https://kicks.dev
KICKSDB_API_KEY=your_kicksdb_api_key

# Gmail sender. The password must be a Google "App Password" (requires 2FA enabled),
# NOT your normal account password. See: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Where the weekly report is sent (can equal GMAIL_ADDRESS).
RECIPIENT_EMAIL=you@gmail.com
